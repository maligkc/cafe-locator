{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "GooglePlaces": {
    "ApiKey": "",
    "BaseUrl": "https://places.googleapis.com/v1/",
    "SearchCacheSeconds": 45,
    "PhotoUriCacheMinutes": 240
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173",
      "http://localhost:5174"
    ]
  },
  "RateLimiting": {
    "PermitLimitPerMinute": 60,
    "QueueLimit": 0
  }
}
